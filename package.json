{
  "name": "@albina-euregio/linea",
  "version": "0.0.0",
  "license": "LGPL-3.0-or-later",
  "files": [
    "demo.html",
    "dist/",
    "src/"
  ],
  "type": "module",
  "main": "./dist/linea.cjs",
  "module": "./dist/linea.js",
  "exports": {
    ".": {
      "import": "./dist/linea.es.js",
      "require": "./dist/linea.cjs.js"
    },
    "./linea": {
      "import": "./dist/linea.es.js",
      "require": "./dist/linea.cjs.js"
    },
    "./aws-stats": {
      "import": "./dist/aws-stats.es.js",
      "require": "./dist/aws-stats.cjs.js"
    },
    "./src/schema/listing": "./src/schema/listing.ts",
    "./src/schema/listing-legacy": "./src/schema/listing-legacy.ts"
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest run",
    "lint": "oxfmt --check && oxlint --max-warnings 12",
    "build": "tsgo && vite build",
    "dev": "vite"
  },
  "dependencies": {
    "air-datepicker": "^3.6.0",
    "temporal-polyfill": "^0.3.0",
    "uplot": "^1.6.32",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "vite": "8.0.2",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "**/*.{js,ts}": "oxlint --fix --max-warnings 0",
    "**/*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.32.1"
}
