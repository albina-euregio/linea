{
  "name": "@albina-euregio/linea",
  "version": "0.0.0",
  "license": "LGPL-3.0-or-later",
  "files": [
    "demo.html",
    "dist/",
    "src/"
  ],
  "type": "module",
  "module": "./dist/linea.mjs",
  "exports": {
    ".": {
      "default": "./dist/linea.mjs"
    },
    "./linea": {
      "default": "./dist/linea.mjs"
    },
    "./aws-stats": {
      "default": "./dist/aws-stats.mjs"
    },
    "./listing": {
      "default": "./dist/listing.mjs",
      "types": "./dist/listing.d.ts"
    },
    "./listing-legacy": {
      "default": "./dist/listing-legacy.mjs",
      "types": "./dist/listing-legacy.d.ts"
    }
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest run",
    "lint": "oxfmt --check && oxlint --max-warnings 12",
    "build": "pnpm run build:tsc && pnpm run build:vite && pnpm run build:listing",
    "build:tsc": "tsc",
    "build:vite": "vite build",
    "build:listing": "tsdown --dts --sourcemap --no-clean src/schema/listing.ts src/schema/listing-legacy.ts",
    "dev": "vite"
  },
  "dependencies": {
    "air-datepicker": "^3.6.0",
    "temporal-polyfill": "^0.3.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2",
    "vite": "8.0.2",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "zod": "^4.3.0"
  },
  "lint-staged": {
    "**/*.{js,ts}": "oxlint --fix --max-warnings 0",
    "**/*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.32.1"
}
